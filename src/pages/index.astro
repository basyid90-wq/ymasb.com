---
import MainLayout from '../layouts/MainLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<MainLayout title="YMASB – Trading, Construction & Maintenance in Malaysia">
<Nav />

<!-- HERO -->
<section class="hero">
  <div class="hero-slides">
    <div class="hero-slide active" style="background-image:url(/images/main-slider/slider3/slide1.jpg)">
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <span class="eyebrow" data-i18n="hero_s1_title">Top Global Commodity</span>
        <h1 class="hero-title" data-i18n="hero_s1_title">Top Global Commodity</h1>
        <p class="hero-desc" data-i18n="hero_s1_desc">Supplying trusted commodities worldwide with strong expertise in import & export, delivering excellence across industries.</p>
        <div class="hero-btns">
          <a href="#contact" class="btn-primary" data-i18n="hero_btn_quote">Get a Quote</a>
          <a href="#projects" class="btn-secondary" data-i18n="hero_btn_projects">View Projects</a>
        </div>
      </div>
    </div>
    <div class="hero-slide" style="background-image:url(/images/main-slider/slider3/slide2.jpg)">
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <span class="eyebrow" data-i18n="hero_s2_title">Driving Trade</span>
        <h1 class="hero-title" data-i18n="hero_s2_title">Driving Trade</h1>
        <p class="hero-desc" data-i18n="hero_s2_desc">From palm oil to rubber, we connect local resources to global markets with efficiency and reliability.</p>
        <div class="hero-btns">
          <a href="#contact" class="btn-primary" data-i18n="hero_btn_quote">Get a Quote</a>
          <a href="#projects" class="btn-secondary" data-i18n="hero_btn_projects">View Projects</a>
        </div>
      </div>
    </div>
    <div class="hero-slide" style="background-image:url(/images/main-slider/slider3/slide3.jpg)">
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <span class="eyebrow" data-i18n="hero_s3_title">Building Beyond Limits</span>
        <h1 class="hero-title" data-i18n="hero_s3_title">Building Beyond Limits</h1>
        <p class="hero-desc" data-i18n="hero_s3_desc">Comprehensive project management, construction, and maintenance solutions that shape progress and growth.</p>
        <div class="hero-btns">
          <a href="#contact" class="btn-primary" data-i18n="hero_btn_quote">Get a Quote</a>
          <a href="#projects" class="btn-secondary" data-i18n="hero_btn_projects">View Projects</a>
        </div>
      </div>
    </div>
  </div>
  <div class="hero-dots">
    <button class="hero-dot active"></button>
    <button class="hero-dot"></button>
    <button class="hero-dot"></button>
  </div>
</section>

<!-- ABOUT -->
<section class="section" id="about">
  <div class="section-max about-grid">
    <div class="about-images">
      <div class="about-img-stack">
        <img src="/images/gallery/portrait/pic4.jpg" alt="YMASB" class="about-img-1"/>
        <img src="/images/gallery/portrait/pic5.png" alt="YMASB" class="about-img-2"/>
      </div>
    </div>
    <div class="about-text">
      <div class="about-since-box">
        <span class="about-since-year" data-i18n="about_since">Since 2017</span>
        <span class="about-since-sub" data-i18n="about_since_sub">committed to quality, safety, and integrity</span>
      </div>
      <span class="eyebrow" data-i18n="about_eyebrow">ABOUT US</span>
      <h2 class="sec-title" data-i18n="about_title">Yahaya Mahmud Enterprise Sdn. Bhd.</h2>
      <p class="sec-body" data-i18n="about_desc">The company was established on 25 August 2017 by Yahaya Bin Mahmud who has a combination of experience in rubber and palm oil trading, construction works, maintenance and project management.</p>
      <div class="about-founder">
        <img src="/images/Signature+Black.png" alt="Signature" class="signature-img"/>
        <div>
          <strong>Yahaya Mahmud</strong>
          <span data-i18n="about_founder">Founder & CEO</span>
        </div>
      </div>
      <a href="#contact" class="btn-primary" data-i18n="about_btn">Get in Touch</a>
    </div>
  </div>
</section>

<!-- SAFETY & QUALITY -->
<section class="section section-dark">
  <div class="section-max tc">
    <span class="eyebrow" data-i18n="safety_eyebrow">EXCELLENCE</span>
    <h2 class="sec-title" data-i18n="safety_title">Safety and Quality</h2>
    <p class="sec-body" data-i18n="safety_desc">Our commitment to integrity and safety is at the core of everything we do.</p>
  </div>
  <div class="section-max safety-grid">
    <div class="safety-card">
      <img src="/images/services/1.png" alt="Quality"/>
      <div class="safety-card-info">
        <h4 data-i18n="safety_1_title">Quality</h4>
        <p data-i18n="safety_1_desc">Trusted Quality — Delivering excellence beyond standards.</p>
      </div>
    </div>
    <div class="safety-card">
      <img src="/images/services/2.png" alt="Safety"/>
      <div class="safety-card-info">
        <h4 data-i18n="safety_2_title">Safety</h4>
        <p data-i18n="safety_2_desc">Safety First — Protecting people and projects at every step.</p>
      </div>
    </div>
    <div class="safety-card">
      <img src="/images/services/3.png" alt="Integrity"/>
      <div class="safety-card-info">
        <h4 data-i18n="safety_3_title">Integrity & Professionalism</h4>
        <p data-i18n="safety_3_desc">Integrity Matters — Building trust through honest work.</p>
      </div>
    </div>
  </div>
</section>

<!-- MISSION -->
<section class="section" id="mission">
  <div class="section-max mission-grid">
    <div class="mission-text">
      <span class="eyebrow" data-i18n="mission_eyebrow">OUR MISSION</span>
      <h2 class="sec-title" data-i18n="mission_title">Our Mission</h2>
      <p class="sec-body" data-i18n="mission_desc">Our mission is to deliver quality products on time and within budget, while building long-term partnerships through innovation, teamwork, and integrity.</p>
      <ul class="mission-list">
        <li data-i18n="mission_list_1">Trading</li>
        <li data-i18n="mission_list_2">Project Management</li>
        <li data-i18n="mission_list_3">Maintenance Delivery</li>
        <li data-i18n="mission_list_4">Construction</li>
        <li data-i18n="mission_list_5">Import & Export Services</li>
      </ul>
    </div>
    <div class="mission-img">
      <img src="/images/mission.jpg" alt="Mission"/>
    </div>
  </div>
</section>

<!-- PARTNERS -->
<section class="section section-dark" id="partners">
  <div class="section-max tc">
    <span class="eyebrow" data-i18n="partners_eyebrow">PARTNERS</span>
    <h2 class="sec-title" data-i18n="partners_title">Our Business Partners</h2>
    <p class="sec-body" data-i18n="partners_desc">Trusted by leading brands</p>
  </div>
  <div class="section-max partners-track-wrap">
    <div class="partners-track">
      {Array.from({length: 2}, () =>
        [1,2,3,4,5,6].map(i => (
          <div class="partner-logo">
            <img src={`/images/partners/partners-${i}.png`} alt={`Partner ${i}`}/>
          </div>
        ))
      )}
    </div>
  </div>
</section>

<!-- SERVICES -->
<section class="section" id="services">
  <div class="section-max tc">
    <span class="eyebrow" data-i18n="services_eyebrow">WHAT WE DO</span>
    <h2 class="sec-title" data-i18n="services_title">Our Services</h2>
    <p class="sec-body" data-i18n="services_desc">We are dedicated to providing the best services across industries.</p>
  </div>
  <div class="section-max svc-grid">
    <div class="svc-card">
      <div class="svc-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      </div>
      <h4 data-i18n="svc_1_title">Trading</h4>
      <p data-i18n="svc_1_desc">Specializing in palm oil, rubber, fertilizer, poultry, and meat.</p>
    </div>
    <div class="svc-card">
      <div class="svc-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="12" width="6" height="10"/><rect x="9" y="6" width="6" height="16"/><rect x="17" y="2" width="6" height="20"/></svg>
      </div>
      <h4 data-i18n="svc_2_title">Construction</h4>
      <p data-i18n="svc_2_desc">Expertise in road construction, civil & structural projects.</p>
    </div>
    <div class="svc-card">
      <div class="svc-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
      </div>
      <h4 data-i18n="svc_3_title">Fabrication & Renovation</h4>
      <p data-i18n="svc_3_desc">High-quality fabrication & building solutions.</p>
    </div>
    <div class="svc-card">
      <div class="svc-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </div>
      <h4 data-i18n="svc_4_title">Asset Maintenance</h4>
      <p data-i18n="svc_4_desc">Comprehensive services to maintain and optimize your assets.</p>
    </div>
  </div>
</section>

<!-- PROJECTS -->
<section class="section section-dark" id="projects">
  <div class="section-max tc">
    <span class="eyebrow" data-i18n="projects_eyebrow">PORTFOLIO</span>
    <h2 class="sec-title" data-i18n="projects_title">Our Projects</h2>
  </div>
  <div class="section-max">
    <div class="filter-bar">
      <button class="filter-btn active" data-filter="all" data-i18n="filter_all">All</button>
      <button class="filter-btn" data-filter="cat-1" data-i18n="filter_1">Commodity Trading</button>
      <button class="filter-btn" data-filter="cat-2" data-i18n="filter_2">Civil & Roadworks</button>
      <button class="filter-btn" data-filter="cat-3" data-i18n="filter_3">Building & Renovation</button>
      <button class="filter-btn" data-filter="cat-4" data-i18n="filter_4">Fabrication & Engineering</button>
      <button class="filter-btn" data-filter="cat-5" data-i18n="filter_5">Asset Maintenance</button>
    </div>
    <div class="project-grid" id="projectGrid">
      {["Rubber-1","Rubber-2","Rubber-3","Rubber-4","Rubber-5","Rubber-6"].map(name => (
        <div class="project-item cat-1"><img src={`/images/services/service-projects/${name}.png`} alt={name}/></div>
      ))}
      {["Roadwork-1","Roadwork-2"].map(name => (
        <div class="project-item cat-2"><img src={`/images/services/service-projects/${name}.png`} alt={name}/></div>
      ))}
      <div class="project-item cat-3"><img src="/images/services/service-projects/Building-1.png" alt="Building"/></div>
      <div class="project-item cat-4"><img src="/images/services/service-projects/Fabrication-1.png" alt="Fabrication"/></div>
      <div class="project-item cat-5"><img src="/images/services/service-projects/Asset-1.png" alt="Asset"/></div>
    </div>
  </div>
</section>

<!-- EXPERIENCE & PROFILE -->
<section class="section" id="experience">
  <div class="section-max exp-grid">
    <div class="exp-left">
      <div class="profile-box">
        <div class="profile-download">
          <h4 data-i18n="profile_title">Company Profile</h4>
          <p data-i18n="profile_desc">Discover more about us — download our company profile.</p>
          <a href="/images/download/YAHAYA-MAHMUD-PROFILE-(LATEST).pdf" class="btn-primary" data-i18n="profile_btn" download>Download</a>
        </div>
        <div class="profile-help">
          <h4 data-i18n="help_title">Let's help you!</h4>
          <p data-i18n="help_desc">If you have any questions about our services, projects, or partnerships, feel free to reach out.</p>
          <a href="#contact" class="btn-secondary" data-i18n="help_btn">Contact Us</a>
        </div>
      </div>
    </div>
    <div class="exp-right">
      <span class="eyebrow" data-i18n="exp_eyebrow">PROVEN TRACK</span>
      <h3 class="sec-title" data-i18n="exp_title">8 Years of Experience</h3>
      <div class="progress-list">
        <div class="prog-item"><span data-i18n="exp_1">Trading & Export</span><div class="prog-bar"><div class="prog-fill" style="--w:97%"><span>97%</span></div></div></div>
        <div class="prog-item"><span data-i18n="exp_2">Construction & Civil Works</span><div class="prog-bar"><div class="prog-fill" style="--w:94%"><span>94%</span></div></div></div>
        <div class="prog-item"><span data-i18n="exp_3">Project Management</span><div class="prog-bar"><div class="prog-fill" style="--w:93%"><span>93%</span></div></div></div>
        <div class="prog-item"><span data-i18n="exp_4">Maintenance & Asset Care</span><div class="prog-bar"><div class="prog-fill" style="--w:92%"><span>92%</span></div></div></div>
        <div class="prog-item"><span data-i18n="exp_5">Fabrication & Engineering</span><div class="prog-bar"><div class="prog-fill" style="--w:91%"><span>91%</span></div></div></div>
      </div>
    </div>
  </div>
</section>

<!-- TIMELINE -->
<section class="section section-dark" id="timeline">
  <div class="section-max tc">
    <span class="eyebrow" data-i18n="timeline_eyebrow">OUR JOURNEY</span>
    <h2 class="sec-title" data-i18n="timeline_title">About Summary</h2>
  </div>
  <div class="section-max timeline">
    <div class="tl-item">
      <div class="tl-year">2017</div>
      <div class="tl-content">
        <img src="/images/gallery/portrait/pic4.jpg" alt="2017" class="tl-img"/>
        <div>
          <h4 data-i18n="tl_2017_title">Inception</h4>
          <p data-i18n="tl_2017_desc">Yahaya Mahmud Enterprise Sdn. Bhd. was established, focusing on supply raw rubber, latex and palm oil.</p>
        </div>
      </div>
    </div>
    <div class="tl-item">
      <div class="tl-year">2019</div>
      <div class="tl-content">
        <img src="/images/gallery/portrait/pic7.png" alt="2019" class="tl-img"/>
        <div>
          <h4 data-i18n="tl_2019_title">Diversification</h4>
          <p data-i18n="tl_2019_desc">Expanded into fertilizer, poultry & meat trading, strengthening supply chain and local market presence.</p>
        </div>
      </div>
    </div>
    <div class="tl-item">
      <div class="tl-year">2021</div>
      <div class="tl-content">
        <img src="/images/gallery/portrait/pic6.png" alt="2021" class="tl-img"/>
        <div>
          <h4 data-i18n="tl_2021_title">Construction Division</h4>
          <p data-i18n="tl_2021_desc">Ventured into civil, structural, and building construction, including renovation and fabrication works.</p>
        </div>
      </div>
    </div>
    <div class="tl-item">
      <div class="tl-year">2023</div>
      <div class="tl-content">
        <img src="/images/gallery/portrait/pic5.png" alt="2023" class="tl-img"/>
        <div>
          <h4 data-i18n="tl_2023_title">Project Management & Maintenance</h4>
          <p data-i18n="tl_2023_desc">Introduced asset maintenance and project management services, delivering quality with integrity and safety.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FAQ & SOLUTIONS -->
<section class="section" id="faq">
  <div class="section-max faq-grid">
    <div>
      <span class="eyebrow" data-i18n="faq_eyebrow">FAQ</span>
      <h2 class="sec-title" data-i18n="faq_title">Frequently Asked Questions</h2>
      <div class="accordion">
        <div class="acc-item open">
          <button class="acc-header"><span data-i18n="faq_1_q">What industries do you serve?</span><span class="acc-icon">+</span></button>
          <div class="acc-body"><p data-i18n="faq_1_a">We focus on trading Palm Oil, Rubber, Fertilizer, Poultry & Meat, as well as Construction, Project Management, and Maintenance.</p></div>
        </div>
        <div class="acc-item">
          <button class="acc-header"><span data-i18n="faq_2_q">Do you provide import and export services?</span><span class="acc-icon">+</span></button>
          <div class="acc-body"><p data-i18n="faq_2_a">Yes, we have extensive experience in local, import, and export trading.</p></div>
        </div>
        <div class="acc-item">
          <button class="acc-header"><span data-i18n="faq_3_q">How do you ensure quality and safety?</span><span class="acc-icon">+</span></button>
          <div class="acc-body"><p data-i18n="faq_3_a">We adhere to over 50 international safety and quality standards.</p></div>
        </div>
        <div class="acc-item">
          <button class="acc-header"><span data-i18n="faq_4_q">Can you handle large-scale projects?</span><span class="acc-icon">+</span></button>
          <div class="acc-body"><p data-i18n="faq_4_a">Absolutely. Our team delivers on time and within budget.</p></div>
        </div>
        <div class="acc-item">
          <button class="acc-header"><span data-i18n="faq_5_q">Where are your operations based?</span><span class="acc-icon">+</span></button>
          <div class="acc-body"><p data-i18n="faq_5_a">We are headquartered in Malaysia, serving both local and international markets.</p></div>
        </div>
      </div>
    </div>
    <div>
      <span class="eyebrow" data-i18n="solution_eyebrow">SOLUTIONS</span>
      <h2 class="sec-title" data-i18n="solution_title">Our Solution</h2>
      <div class="sol-cards">
        <div class="sol-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:32px;height:32px;color:var(--primary)"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
          <h4 data-i18n="sol_1_title">Global Reach</h4>
          <p data-i18n="sol_1_desc">Strong trading network connecting local commodities to international markets.</p>
        </div>
        <div class="sol-card sol-card-dark">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:32px;height:32px;color:var(--primary)"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
          <h4 data-i18n="sol_2_title">Sustainability</h4>
          <p data-i18n="sol_2_desc">Commitment to long-term partnerships and contributions to the communities we serve.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CONTACT -->
<section class="section section-dark" id="contact">
  <div class="section-max tc">
    <span class="eyebrow" data-i18n="contact_eyebrow">GET IN TOUCH</span>
    <h2 class="sec-title" data-i18n="contact_title">Contact Us</h2>
  </div>
  <div class="section-max contact-grid">
    <form id="waForm" class="contact-form">
      <input type="text" name="username" placeholder="Name" data-i18n-ph="contact_name" required/>
      <input type="email" name="email" placeholder="Email" data-i18n-ph="contact_email" required/>
      <input type="tel" name="phone" placeholder="Phone" data-i18n-ph="contact_phone" required/>
      <textarea name="message" placeholder="Message" data-i18n-ph="contact_message" rows="4" required></textarea>
      <button type="submit" class="btn-primary" data-i18n="contact_send">Send via WhatsApp</button>
    </form>
    <div class="contact-info-box">
      <div class="ci-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:20px;height:20px"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        <div><strong>Phone</strong><p>+6011-5500 8889</p></div>
      </div>
      <div class="ci-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:20px;height:20px"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <div><strong>Email</strong><p>admin@ymasb.com</p></div>
      </div>
      <div class="ci-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:20px;height:20px"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <div><strong>Address</strong><p>Lot No 130, Kuala Ketil Commercial Center (KKCC), 09300 Kuala Ketil, Kedah</p></div>
      </div>
      <div class="ci-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:20px;height:20px"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <div><strong>Hours</strong><p>Mon-Fri : 10.00am - 6.00pm</p></div>
      </div>
    </div>
  </div>
</section>

<!-- WHATSAPP FLOAT -->
<a class="wa-float" href="https://wa.me/601155008889" target="_blank" rel="noopener" aria-label="WhatsApp">
